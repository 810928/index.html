<script>
// ── STATE ──
let webhookUrl = localStorage.getItem('jb_webhook') || '';
let queue = JSON.parse(localStorage.getItem('jb_queue') || '[]');
let leads = JSON.parse(localStorage.getItem('jb_leads') || '[]');
let currentAnalysis = null;
let currentQueueId = null;

// ── INIT ──
if(webhookUrl){ document.getElementById('webhook-url').value = webhookUrl; setConnected(true); }
renderQueue();
renderLeads();
updateBadge();

// ── NAVIGATION ──
function showPage(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.bnav-item').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.desktop-nav-item').forEach(d=>d.classList.remove('active'));
  const page = document.getElementById('page-'+name);
  if(page) page.classList.add('active');
  const bn = document.getElementById('bn-'+name);
  if(bn) bn.classList.add('active');
  const dn = document.querySelector(`.desktop-nav-item[onclick="showPage('${name}')"]`);
  if(dn) dn.classList.add('active');
}

// ── SHEET ──
function connectSheet(){
  const url = document.getElementById('webhook-url').value.trim();
  if(!url.startsWith('https://script.google.com')){ showToast('Invalid URL'); return; }
  webhookUrl = url;
  localStorage.setItem('jb_webhook', url);
  setConnected(true);
  showToast('Sheet connected!');
}
function setConnected(yes){
  document.getElementById('sdot').className = yes ? 'sdot on' : 'sdot pulse';
  document.getElementById('stext').textContent = yes ? 'Sheet on' : 'No sheet';
}

// ── TOAST ──
function showToast(msg, duration=2200){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), duration);
}

// ── BADGE ──
function updateBadge(){
  const pending = queue.filter(q=>!q.verdict).length;
  const total = queue.length;
  ['bn-badge','dn-badge'].forEach(id=>{
    const el = document.getElementById(id);
    if(!el) return;
    if(total > 0){ el.textContent = total; el.style.display='inline-block'; }
    else el.style.display='none';
  });
}

// ── SAVE LISTING (Stage 1) ──
function saveListing(){
  const text = document.getElementById('listing-input').value.trim();
  if(!text){ showToast('Nothing to save — paste a listing first'); return; }
  const id = Date.now().toString();
  const preview = text.split('\n').find(l=>l.trim().length > 4) || text.substring(0,60);
  const item = { id, raw: text, preview: preview.trim(), date: new Date().toLocaleDateString('en-MY'), verdict: null, data: null };
  queue.unshift(item);
  localStorage.setItem('jb_queue', JSON.stringify(queue));
  document.getElementById('listing-input').value = '';
  updateBadge();
  renderQueue();
  showToast('Saved to queue');
  showPage('queue');
}

// ── QUEUE ──
function renderQueue(){
  const el = document.getElementById('queue-list');
  const empty = document.getElementById('queue-empty');
  if(!queue.length){ el.style.display='none'; empty.style.display='flex'; return; }
  empty.style.display='none'; el.style.display='flex';
  el.innerHTML = queue.map(item=>{
    const badgeClass = !item.verdict ? 'badge-pending' : item.verdict==='Promote' ? 'badge-promote' : item.verdict==='Skip' ? 'badge-skip' : 'badge-caution';
    const badgeText = item.verdict || 'Pending';
    return `<div class="saved-card" onclick="openAnalysis('${item.id}')">
      <div class="saved-card-title">${escHtml(item.preview)}</div>
      <div class="saved-card-meta">${escHtml(item.raw.substring(0,120))}</div>
      <div class="saved-card-footer">
        <div class="saved-card-date">${item.date}</div>
        <span class="status-badge ${badgeClass}">${badgeText}</span>
      </div>
      <button class="delete-btn" onclick="deleteItem(event,'${item.id}')">×</button>
    </div>`;
  }).join('');
}

function deleteItem(e, id){
  e.stopPropagation();
  queue = queue.filter(q=>q.id !== id);
  localStorage.setItem('jb_queue', JSON.stringify(queue));
  renderQueue();
  updateBadge();
  showToast('Removed');
}

function escHtml(s){ return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── ANALYSIS MODAL (Stage 2) ──
async function openAnalysis(id){
  const item = queue.find(q=>q.id===id);
  if(!item) return;
  currentQueueId = id;

  // If already analysed, just show results
  if(item.data){
    currentAnalysis = item.data;
    showModal(item);
    showResults(item.data);
    return;
  }

  // Start fresh analysis
  showModal(item);
  await runAnalysis(item);
}

function showModal(item){
  document.getElementById('modal-title').textContent = item.preview;
  document.getElementById('modal-loading').style.display = 'flex';
  document.getElementById('modal-results').style.display = 'none';
  document.getElementById('analysis-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(){
  document.getElementById('analysis-modal').classList.remove('open');
  document.body.style.overflow = '';
}

async function runAnalysis(item){
  const activeLeads = leads.filter(l=>l.name && l.name.trim());
  const leadsText = activeLeads.length
    ? activeLeads.map((l,i)=>`Lead ${i+1}: ${l.name} | Budget: ${l.budget} | Area: ${l.area} | Type: ${l.type} | Requirements: ${l.notes}`).join('\n')
    : 'No leads configured.';

  const msgs = ['Analysing listing...','Checking market prices...','Matching leads...','Generating report...'];
  let mi = 0;
  const msgEl = document.getElementById('loading-msg');
  const msgInterval = setInterval(()=>{ msgEl.textContent = msgs[Math.min(++mi, msgs.length-1)]; }, 2500);

  const prompt = `You are an expert JB (Johor Bahru) Malaysia property analyst for subsale residential properties. Analyse this listing and return ONLY valid JSON, no markdown, no text outside the JSON.

LISTING:
${item.raw}

ACTIVE LEADS:
${leadsText}

JB subsale PSF reference (2024-2025):
- Horizon Hills: RM280-380 PSF (landed cluster)
- Bukit Indah: RM260-340 PSF (landed)
- Medini/Puteri Harbour: RM400-600 PSF (condo)
- Setia Tropika: RM250-320 PSF (landed)
- Mount Austin/Tebrau: RM220-300 PSF
- Permas Jaya: RM200-280 PSF
- Danga Bay/KSL: RM350-500 PSF (condo)
- Eco Botanic: RM270-360 PSF (landed)
- Nusa Bestari/Skudai: RM200-280 PSF

Return EXACTLY this JSON:
{
  "property_name": "project or address",
  "area": "neighbourhood in JB",
  "price": "e.g. RM780,000",
  "price_num": 780000,
  "psf_listing": 278,
  "psf_market_avg": 320,
  "built_up": "2800 sqft",
  "land_area": "3500 sqft or null",
  "bedrooms": "4+1",
  "bathrooms": "3",
  "tenure": "Freehold or Leasehold or Unknown",
  "furnishing": "Fully / Partial / Unfurnished / Unknown",
  "condition": "Renovated / Original / New / Unknown",
  "seller_motivation": "High / Medium / Low",
  "motivation_reason": "short reason",
  "price_assessment": "Below Market / At Market / Above Market",
  "price_gap_pct": -13,
  "market_commentary": "2-3 sentences: price vs market, value drivers, worth promoting?",
  "verdict": "Promote / Caution / Skip",
  "verdict_reason": "1-2 sentences explaining verdict",
  "lead_matches": [{"lead_name":"name","match_level":"High / Medium / Low","match_reason":"specific reason referencing their criteria"}],
  "next_action": "specific actionable next step right now",
  "wa_message": "Full WhatsApp message in friendly Manglish to best matched lead. 4-6 lines, natural tone, key highlights, soft call to view."
}`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1400,messages:[{role:'user',content:prompt}]})
    });
    const data = await res.json();
    const raw = data.content.map(i=>i.text||'').join('').replace(/```json|```/g,'').trim();
    const d = JSON.parse(raw);
    d.date = item.date;
    d.raw_listing = item.raw;
    currentAnalysis = d;

    // Update queue item with verdict + data
    const idx = queue.findIndex(q=>q.id===item.id);
    if(idx>-1){ queue[idx].verdict = d.verdict; queue[idx].data = d; queue[idx].preview = d.property_name || item.preview; }
    localStorage.setItem('jb_queue', JSON.stringify(queue));
    renderQueue();
    updateBadge();
    showResults(d);
  } catch(err){
    clearInterval(msgInterval);
    closeModal();
    showToast('Analysis failed — try again');
  } finally {
    clearInterval(msgInterval);
  }
}

function showResults(d){
  document.getElementById('modal-loading').style.display = 'none';
  const res = document.getElementById('modal-results');
  res.style.display = 'flex';
  res.style.flexDirection = 'column';
  res.style.gap = '14px';
  document.getElementById('modal-title').textContent = d.property_name || '—';

  // Verdict banner
  const vClass = d.verdict==='Promote'?'vb-promote':d.verdict==='Skip'?'vb-skip':'vb-caution';
  const vLabel = d.verdict==='Promote'?'Promote this listing':d.verdict==='Skip'?'Skip — not worth your time':'Proceed with caution';
  document.getElementById('r-verdict-banner').innerHTML = `<div class="verdict-banner ${vClass}"><div class="verdict-title">${vLabel}</div><div class="verdict-body">${d.verdict_reason||''}</div></div>`;

  // Metrics
  document.getElementById('r-metrics').innerHTML = `
    <div class="metric-cell"><div class="metric-label">Price</div><div class="metric-value">${d.price||'—'}</div></div>
    <div class="metric-cell"><div class="metric-label">PSF</div><div class="metric-value">${d.psf_listing?'RM'+d.psf_listing:'—'}</div><div class="metric-sub">Mkt avg: RM${d.psf_market_avg||'—'}</div></div>
    <div class="metric-cell"><div class="metric-label">Size</div><div class="metric-value">${d.built_up||'—'}</div><div class="metric-sub">${d.land_area?'Land: '+d.land_area:''}</div></div>
    <div class="metric-cell"><div class="metric-label">Rooms</div><div class="metric-value">${d.bedrooms||'—'}/${d.bathrooms||'—'}</div><div class="metric-sub">bed/bath</div></div>
  `;

  // Details
  const motColor = d.seller_motivation==='High'?'var(--green)':d.seller_motivation==='Low'?'var(--red)':'var(--amber)';
  document.getElementById('r-details').innerHTML = [
    ['Tenure', d.tenure],
    ['Furnishing', d.furnishing],
    ['Condition', d.condition],
    ['Motivation', `<span style="color:${motColor}">${d.seller_motivation||'—'}${d.motivation_reason?' — '+d.motivation_reason:''}</span>`]
  ].map(([k,v])=>`<div class="detail-row"><span class="detail-key">${k}</span><span class="detail-val">${v||'—'}</span></div>`).join('');

  // Market price
  const pct = parseFloat(d.price_gap_pct)||0;
  const pctStr = pct===0?'At market':pct<0?Math.abs(pct)+'% below market':'+'+pct+'% above market';
  const pctColor = pct<-5?'var(--green)':pct>5?'var(--red)':'var(--amber)';
  document.getElementById('r-gap').textContent = pctStr;
  document.getElementById('r-gap').style.color = pctColor;
  const aTag = d.price_assessment||'—';
  const aClass = aTag.includes('Below')?'badge-promote':aTag.includes('Above')?'badge-skip':'badge-caution';
  document.getElementById('r-price-tag').innerHTML = `<span class="status-badge ${aClass}">${aTag}</span>`;
  document.getElementById('r-commentary').textContent = d.market_commentary||'—';

  // PSF bar
  if(d.psf_listing && d.psf_market_avg){
    const maxP = Math.max(d.psf_listing,d.psf_market_avg)*1.2;
    const lPct = Math.round((d.psf_listing/maxP)*100);
    const mPct = Math.round((d.psf_market_avg/maxP)*100);
    document.getElementById('r-psf-bar').innerHTML = `
      <div class="psf-bar-labels"><span>RM${d.psf_listing}/sqft</span><span>Mkt RM${d.psf_market_avg}/sqft</span></div>
      <div class="psf-bar-track"><div style="height:8px;border-radius:4px;background:var(--surface3);width:${mPct}%"></div><div class="psf-marker" style="left:${lPct}%;background:${pctColor}"></div></div>
      <div class="psf-note">Dot = this listing &nbsp;|&nbsp; Bar = market average</div>
    `;
  }

  // Lead matches
  if(d.lead_matches && d.lead_matches.length){
    const high = d.lead_matches.filter(m=>m.match_level==='High').length;
    document.getElementById('r-match-count').textContent = high ? high+' high match'+(high>1?'es':'') : '';
    document.getElementById('r-leads').innerHTML = d.lead_matches.map(m=>{
      const cls = m.match_level==='High'?'lm-high':m.match_level==='Low'?'lm-low':'lm-med';
      return `<div class="lead-match ${cls}"><div class="lm-name">${m.lead_name}<span class="lm-badge">${m.match_level}</span></div><div class="lm-reason">${m.match_reason}</div></div>`;
    }).join('');
  } else {
    document.getElementById('r-leads').innerHTML = '<p style="font-size:13px;color:var(--text3);text-align:center;padding:10px">No leads added — go to Leads tab to add them.</p>';
  }

  // WhatsApp
  document.getElementById('r-wa').textContent = d.wa_message||'—';

  // Property Master copy
  const matched = (d.lead_matches||[]).filter(m=>m.match_level==='High').map(m=>m.lead_name).join(', ')||'None';
  document.getElementById('r-pm').textContent = [
    'PROPERTY: '+(d.property_name||'—'),
    'AREA: '+(d.area||'—'),
    'PRICE: '+(d.price||'—'),
    'PSF: RM'+(d.psf_listing||'—')+'/sqft',
    'BUILT UP: '+(d.built_up||'—'),
    'LAND AREA: '+(d.land_area||'N/A'),
    'BEDROOMS: '+(d.bedrooms||'—'),
    'BATHROOMS: '+(d.bathrooms||'—'),
    'TENURE: '+(d.tenure||'—'),
    'FURNISHING: '+(d.furnishing||'—'),
    'CONDITION: '+(d.condition||'—'),
    'SELLER MOTIVATION: '+(d.seller_motivation||'—')+(d.motivation_reason?' — '+d.motivation_reason:''),
    'PRICE ASSESSMENT: '+(d.price_assessment||'—')+(d.price_gap_pct?' ('+(d.price_gap_pct>0?'+':'')+d.price_gap_pct+'% vs market)':''),
    'VERDICT: '+(d.verdict||'—'),
    'MATCHED LEADS: '+matched,
    'AGENT NOTE: '+(d.next_action||'—'),
    'DATE: '+(d.date||new Date().toLocaleDateString('en-MY')),
  ].join('\n');

  // Next action
  document.getElementById('r-action').textContent = d.next_action||'—';
}

// ── COPY FUNCTIONS ──
function copyWA(){
  const txt = document.getElementById('r-wa').textContent;
  navigator.clipboard.writeText(txt).then(()=>showToast('WhatsApp message copied!'));
}
function copyPM(){
  const txt = document.getElementById('r-pm').textContent;
  navigator.clipboard.writeText(txt).then(()=>showToast('Copied for Property Master!'));
}

// ── SAVE TO SHEET ──
async function saveToSheet(){
  if(!webhookUrl){ showToast('Connect Google Sheet in Settings first'); return; }
  if(!currentAnalysis){ return; }
  const d = currentAnalysis;
  const btn = document.getElementById('save-sheet-btn');
  btn.textContent='Saving...'; btn.disabled=true;
  try {
    await fetch(webhookUrl,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      action:'save_listing',date:d.date,property:d.property_name,area:d.area,price:d.price,
      psf:d.psf_listing,built_up:d.built_up,land:d.land_area,beds:d.bedrooms,baths:d.bathrooms,
      tenure:d.tenure,furnishing:d.furnishing,condition:d.condition,motivation:d.seller_motivation,
      assessment:d.price_assessment,gap_pct:d.price_gap_pct,verdict:d.verdict,commentary:d.market_commentary,
      matched_leads:(d.lead_matches||[]).filter(m=>m.match_level==='High').map(m=>m.lead_name).join(', '),
      next_action:d.next_action,raw_listing:d.raw_listing
    })});
    showToast('Saved to Google Sheet!');
  } catch(e){ showToast('Save failed — check sheet connection'); }
  finally{ btn.textContent='Save to Google Sheet'; btn.disabled=false; }
}

// ── LEADS ──
function saveLeads(){ localStorage.setItem('jb_leads', JSON.stringify(leads)); if(webhookUrl) syncLeadsToSheet(); }
function renderLeads(){
  const el = document.getElementById('leads-list');
  if(!leads.length){ el.innerHTML='<p style="font-size:13px;color:var(--text3);text-align:center;padding:16px">No leads yet.</p>'; return; }
  el.innerHTML = leads.map((l,i)=>`
    <div class="lead-card">
      <button class="remove-lead" onclick="removeLead(${i})">×</button>
      <div class="lead-fields">
        <div class="lead-field"><label>Name</label><input type="text" value="${l.name||''}" placeholder="Ahmad" oninput="leads[${i}].name=this.value;saveLeads()"></div>
        <div class="lead-field"><label>Budget</label><input type="text" value="${l.budget||''}" placeholder="RM700k–RM850k" oninput="leads[${i}].budget=this.value;saveLeads()"></div>
        <div class="lead-field"><label>Area</label><input type="text" value="${l.area||''}" placeholder="Horizon Hills" oninput="leads[${i}].area=this.value;saveLeads()"></div>
        <div class="lead-field"><label>Type</label><input type="text" value="${l.type||''}" placeholder="Landed / Condo" oninput="leads[${i}].type=this.value;saveLeads()"></div>
        <div class="lead-field full"><label>Requirements</label><input type="text" value="${l.notes||''}" placeholder="Freehold, min 4 bed, near school" oninput="leads[${i}].notes=this.value;saveLeads()"></div>
      </div>
    </div>
  `).join('');
}
function addLead(){ leads.push({name:'',budget:'',area:'',type:'',notes:''}); saveLeads(); renderLeads(); }
function removeLead(i){ if(!confirm('Remove this lead?')) return; leads.splice(i,1); saveLeads(); renderLeads(); }
async function syncLeadsToSheet(){
  if(!webhookUrl) return;
  try{ await fetch(webhookUrl,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'save_leads',leads})}); }catch(e){}
}
async function syncLeadsFromSheet(){
  if(!webhookUrl){ showToast('Connect sheet in Settings first'); return; }
  showToast('Syncing...');
  try{
    const res = await fetch(webhookUrl,{mode:'cors'});
    const data = await res.json();
    if(Array.isArray(data)&&data.length){ leads=data; localStorage.setItem('jb_leads',JSON.stringify(leads)); renderLeads(); showToast(data.length+' leads loaded'); }
    else showToast('No leads in sheet yet');
  }catch(e){ showToast('Sync failed — check connection'); }
}
</script>
